# Copy to .env if you need to override anything. Defaults in docker-compose.yml
# already work out of the box.

# Postgres
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=onq_challenge

# API
DATABASE_URL=postgres://dev:dev@postgres:5432/onq_challenge
ENRICHMENT_API_URL=http://enrichment-api:4000
ENRICHMENT_API_KEY=dev-secret-key

# Web
VITE_API_URL=http://localhost:3000
