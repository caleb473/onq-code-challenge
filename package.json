{
  "name": "onq-code-challenge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Coding challenge environment",
  "scripts": {
    "dev": "docker compose up",
    "dev:build": "docker compose up --build",
    "dev:detached": "docker compose up -d",
    "stop": "docker compose down",
    "reset": "docker compose down -v && docker compose up --build",
    "seed": "docker compose exec api yarn db:seed",
    "logs": "docker compose logs -f",
    "logs:api": "docker compose logs -f api",
    "logs:web": "docker compose logs -f web",
    "psql": "docker compose exec postgres psql -U dev -d onq_challenge"
  },
  "packageManager": "yarn@4.6.0"
}
